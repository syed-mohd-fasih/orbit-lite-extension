{
	"manifest_version": 3,
	"name": "Orbit Lite",
	"version": "1.0.0",
	"description": "Offline-first student toolkit — parses the university portal into local SQLite.",
	"permissions": ["storage", "nativeMessaging", "tabs"],
	"host_permissions": ["https://flexstudent.nu.edu.pk/*"],
	"background": {
		"service_worker": "background.js"
	},
	"action": {
		"default_popup": "popup.html",
		"default_title": "Orbit Lite",
		"default_icon": "icons/orbit_icon.png"
	},
	"icons": {
		"16": "icons/orbit_icon.png",
		"48": "icons/orbit_icon.png",
		"128": "icons/orbit_icon.png"
	},
	"content_scripts": [
		{
			"matches": ["https://flexstudent.nu.edu.pk/*"],
			"js": ["content.js"],
			"run_at": "document_idle"
		}
	]
}
